# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI provider ---
# "anthropic" (default) or "openai" (also works for Grok/any OpenAI-compatible
# endpoint by overriding OPENAI_BASE_URL below).
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Fallback / alternate provider
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Point this at https://api.x.ai/v1 to use Grok instead of OpenAI.
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Payments (optional for local dev) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
